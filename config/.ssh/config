# GitHub SSH configuration for Nano Review
# This file is copied into /root/.ssh/config during Docker build

Host github.com
    Hostname github.com
    User git
    IdentityFile /root/.ssh/deploy_key
    IdentitiesOnly yes
    StrictHostKeyChecking no
    UserKnownHostsFile=/dev/null
    # Disable SSH connection sharing to avoid issues in ephemeral containers
    ControlMaster no
    ControlPath no
