# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary
*.test

# Output of go coverage tool
*.out

# Go workspace file
go.work
go.work.sum

# Dependency directories
vendor/

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Environment
.env
.env.local

# Application logs
/app/logs/

# AI generated docs (keep README.md)
docs/ai_generated/*
!docs/ai_generated/README.md

# SSH private keys - NEVER commit these
keys/deploy_key
keys/deploy_key.pem
keys/id_rsa
keys/id_ed25519
keys/*.key
keys/*.pem
!keys/*.pub
